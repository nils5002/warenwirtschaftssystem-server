# Production runtime environment
APP_NAME=Warehouse-System
APP_ENV=production

BASE_URL=https://warehouse.example.com
FRONTEND_URL=https://warehouse.example.com
CORS_ORIGINS=https://warehouse.example.com

# Backend / DB
DATABASE_URL=sqlite:///./app/data/app.db
DB_AUTO_CREATE_SCHEMA=true
WMS_SEED_LEGACY_ON_STARTUP=false
HARDWARE_IMPORT_PATH=/app/data/hardware_imports
BACKUP_PATH=/app/data/backups

# Frontend
VITE_API_URL=/api
VITE_API_BASE=
VITE_PROXY_TARGET=http://backend:8000

# Secrets
AUTH_TOKEN_SECRET=change-me-generate-a-long-random-secret
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me
INITIAL_ADMIN_NAME=Admin
