services:
  backend:
    environment:
      APP_ENV: production
      DB_AUTO_CREATE_SCHEMA: "false"
      WMS_SEED_LEGACY_ON_STARTUP: "false"
    # In Produktion intern betreiben; Zugriff ueber Reverse Proxy
    ports: []
    restart: unless-stopped

  postgres:
    ports: []
    restart: unless-stopped
