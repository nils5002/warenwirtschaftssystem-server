APP_NAME=Warehouse-System
APP_ENV=production

BASE_URL=https://warehouse.example.com
FRONTEND_URL=https://warehouse.example.com

VITE_API_URL=/api
VITE_API_BASE=
VITE_PROXY_TARGET=http://backend:8000
VITE_ALLOWED_HOSTS=localhost,127.0.0.1

CORS_ORIGINS=https://warehouse.example.com,http://localhost:5173,http://127.0.0.1:5173

FRONTEND_PORT=8080
BACKEND_PORT=8001

# WICHTIG: Der DATABASE_URL MUSS auf das persistente Volume zeigen, das in
# docker-compose.yml unter `volumes: warehouse_app_data:/app/data` gemountet
# ist. Eine RELATIVE URL wie `sqlite:///./app/data/app.db` löst innerhalb des
# Containers (WORKDIR=/app) zu /app/app/data/app.db auf — also AUSSERHALB des
# Volumes — und führt zu Datenverlust beim Redeploy. Vier Slashes nach
# `sqlite:` = absoluter Pfad.
DATABASE_URL=sqlite:////app/data/app.db
DB_AUTO_CREATE_SCHEMA=true
WMS_SEED_LEGACY_ON_STARTUP=false

HARDWARE_IMPORT_PATH=/app/data/hardware_imports
BACKUP_PATH=/app/data/backups

AUTH_TOKEN_SECRET=change-me-generate-a-long-random-secret

INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me
INITIAL_ADMIN_NAME=Admin
